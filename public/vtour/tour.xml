		<hotspot name="spot1972035432" style="info_hotspot" ath="-18.794" atv="11.117" depth="1000.0" linkedscene="scene_seine_hotel" linkedscene_hoffset="0.0" use3dtransition="true" linkedscene_text="Hotel du Departement" />
